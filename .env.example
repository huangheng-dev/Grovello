GROVELLO_ENVIRONMENT=development

# Public web configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Database
POSTGRES_DB=grovello
POSTGRES_USER=grovello
POSTGRES_PASSWORD=grovello
GROVELLO_DATABASE_URL=postgresql+asyncpg://grovello:grovello@postgres:5432/grovello

# Runtime coordination
GROVELLO_VALKEY_URL=redis://valkey:6379/0
GROVELLO_TEMPORAL_ADDRESS=temporal:7233
GROVELLO_TEMPORAL_NAMESPACE=default
GROVELLO_TEMPORAL_TASK_QUEUE=grovello-growth

# S3-compatible object storage
GROVELLO_OBJECT_STORAGE_ENDPOINT=http://object-storage:9000
GROVELLO_OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
GROVELLO_OBJECT_STORAGE_REGION=us-east-1
GROVELLO_OBJECT_STORAGE_BUCKET=grovello
GROVELLO_OBJECT_STORAGE_ACCESS_KEY_ID=
GROVELLO_OBJECT_STORAGE_SECRET_ACCESS_KEY=
GROVELLO_OBJECT_STORAGE_FORCE_PATH_STYLE=true
GROVELLO_OBJECT_STORAGE_SSE_MODE=none
GROVELLO_OBJECT_STORAGE_KMS_KEY_ID=
GROVELLO_OBJECT_STORAGE_CONNECT_TIMEOUT_SECONDS=5
GROVELLO_OBJECT_STORAGE_READ_TIMEOUT_SECONDS=30
GROVELLO_ASSET_MAX_UPLOAD_BYTES=104857600
GROVELLO_ASSET_UPLOAD_TTL_SECONDS=1800
GROVELLO_IMPORT_MAX_SOURCE_BYTES=26214400
GROVELLO_IMPORT_UPLOAD_TTL_SECONDS=1800
GROVELLO_IMPORT_MAX_ROWS=10000
GROVELLO_IMPORT_MAX_COLUMNS=100
GROVELLO_IMPORT_MAX_SCALAR_BYTES=65536
GROVELLO_IMPORT_MAX_JSON_DEPTH=12
GROVELLO_IMPORT_PREVIEW_ROWS=50
GROVELLO_ASSET_DOWNLOAD_TTL_SECONDS=60

# Replaceable malware scanner. ClamAV is the local reference implementation and remains internal.
GROVELLO_ASSET_SCANNER_PROVIDER=clamav
GROVELLO_ASSET_SCANNER_HOST=malware-scanner
GROVELLO_ASSET_SCANNER_PORT=3310
GROVELLO_ASSET_SCANNER_CONNECT_TIMEOUT_SECONDS=5
GROVELLO_ASSET_SCANNER_TIMEOUT_SECONDS=120
GROVELLO_ASSET_SCANNER_MAX_STREAM_BYTES=104857600

# Local MinIO administration. Use distinct values; the application never receives these.
GROVELLO_OBJECT_STORAGE_ROOT_USER=
GROVELLO_OBJECT_STORAGE_ROOT_PASSWORD=
GROVELLO_OBJECT_STORAGE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3200,http://127.0.0.1:3200,http://localhost:8080,http://127.0.0.1:8080

# Authentication and authorization
OIDC_ISSUER=http://keycloak:8080/realms/grovello
OIDC_CLIENT_ID=grovello-web
OIDC_CLIENT_SECRET=
OPENFGA_API_URL=http://openfga:8080
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=

# Optional model providers. Never commit real values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
QWEN_API_KEY=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
